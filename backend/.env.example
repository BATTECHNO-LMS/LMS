NODE_ENV=development
PORT=4000
API_VERSION=v1

# PostgreSQL — copy to backend/.env (never commit .env)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Neon: if `npx prisma migrate deploy` times out (P1002 advisory lock), use the direct
# connection string (host without `-pooler`) for migrations, then your app may use the pooler URL.
# P1017 / "Server has closed the connection": prefer the pooled URL for the app; the API retries transient drops.

# JWT — required in production (min length enforced via JWT_SECRET_MIN_LENGTH)
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_SECRET_MIN_LENGTH=32

STUDENT_ROLE_CODE=student
SUPER_ADMIN_ROLE_CODE=super_admin

# CORS: comma-separated browser origins (required when NODE_ENV=production)
# Example: https://app.example.com,https://admin.example.com
CORS_ORIGINS=http://localhost:5173

# Behind reverse proxy (nginx, load balancer) — enables correct client IP for rate limiting
TRUST_PROXY=false

# Rate limits (per IP, per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=30

# File storage
UPLOAD_DIR=uploads
# Absolute public origin for API (no trailing slash) — used to build file URLs for clients
PUBLIC_BASE_URL=
# local | s3
STORAGE_BACKEND=local
# When using S3-compatible storage with public bucket/CDN
S3_PUBLIC_BASE_URL=

# Role code env blocks (see src/config/env.js for defaults). Do not set these to an empty value:
# an empty list would deny everyone except global (super) admins unless you rely on isGlobal bypass.
# If you override CURRICULUM_READ_ROLE_CODES, include instructor so teaching routes (e.g. learning outcomes under a micro-credential) are not 403.
