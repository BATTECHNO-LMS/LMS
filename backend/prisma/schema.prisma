/// Issued micro-credential certificates (verification + lifecycle).
model certificates {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id          String             @db.Uuid
  cohort_id           String             @db.Uuid
  micro_credential_id String             @db.Uuid
  certificate_no      String             @unique @db.VarChar(80)
  verification_code   String             @unique @db.VarChar(64)
  qr_code_url         String?
  status              certificate_status @default(issued)
  issued_at           DateTime           @default(now()) @db.Timestamptz(6)
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  updated_at          DateTime           @default(now()) @db.Timestamptz(6)

  @@unique([student_id, cohort_id, micro_credential_id], map: "uq_certificates_student_cohort_mc")
  @@index([student_id], map: "idx_certificates_student_id")
  @@index([cohort_id], map: "idx_certificates_cohort_id")
  @@index([micro_credential_id], map: "idx_certificates_micro_credential_id")
  @@index([status], map: "idx_certificates_status")
}

