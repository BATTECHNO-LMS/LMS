  university_id String?  @db.Uuid
  action_type   String   @db.VarChar(120)
  entity_type   String   @db.VarChar(120)
  entity_id     String?  @db.Uuid
  old_values    Json?
  new_values    Json?
  ip_address    String?  @db.VarChar(64)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "idx_audit_logs_user_id")
  @@index([university_id], map: "idx_audit_logs_university_id")
  @@index([action_type], map: "idx_audit_logs_action_type")
  @@index([entity_type], map: "idx_audit_logs_entity_type")
  @@index([created_at], map: "idx_audit_logs_created_at")
