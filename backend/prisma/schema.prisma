generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cohorts {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  micro_credential_id String         @db.Uuid
  university_id       String         @db.Uuid
  instructor_id       String?        @db.Uuid
  title               String         @db.VarChar(255)
  start_date          DateTime       @db.Date
  end_date            DateTime       @db.Date
  capacity            Int
  status              cohort_status  @default(planned)
  created_at          DateTime       @default(now()) @db.Timestamptz(6)
  updated_at          DateTime       @default(now()) @db.Timestamptz(6)
  assessments         assessments[]

  @@index([instructor_id], map: "idx_cohorts_instructor_id")
  @@index([micro_credential_id], map: "idx_cohorts_micro_credential_id")
  @@index([status], map: "idx_cohorts_status")
  @@index([university_id], map: "idx_cohorts_university_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model contents {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  module_id    String       @db.Uuid
  title        String       @db.VarChar(255)
  content_type content_type
  file_url     String?
  external_url String?
  sequence_no  Int
  publish_at   DateTime?    @db.Timestamptz(6)
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  updated_at   DateTime     @default(now()) @db.Timestamptz(6)

  @@unique([module_id, sequence_no], map: "uq_contents_sequence")
  @@index([module_id], map: "idx_contents_module_id")
}

model corrective_actions {
  id           String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  qa_review_id String                   @db.Uuid
  assigned_to  String?                  @db.Uuid
  action_text  String
  due_date     DateTime                 @db.Date
  status       corrective_action_status @default(open)
  closed_at    DateTime?                @db.Timestamptz(6)
  created_at   DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at   DateTime                 @default(now()) @db.Timestamptz(6)

  @@index([qa_review_id], map: "idx_corrective_actions_qa_review_id")
  @@index([status], map: "idx_corrective_actions_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model enrollments {
  id                             String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cohort_id                      String                          @db.Uuid
  student_id                     String                          @db.Uuid
  enrollment_status              enrollment_status               @default(pending)
  final_status                   final_status                    @default(in_progress)
  final_grade                    Decimal?                        @db.Decimal(5, 2)
  attendance_percentage          Decimal?                        @default(0) @db.Decimal(5, 2)
  enrolled_at                    DateTime                        @default(now()) @db.Timestamptz(6)
  completion_date                DateTime?                       @db.Date
  certificate_issued_at          DateTime?                       @db.Timestamptz(6)
  recognition_eligibility_status recognition_eligibility_status? @default(unknown)
  created_at                     DateTime                        @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime                        @default(now()) @db.Timestamptz(6)

  @@unique([cohort_id, student_id], map: "uq_enrollments")
  @@index([cohort_id], map: "idx_enrollments_cohort_id")
  @@index([final_status], map: "idx_enrollments_final_status")
  @@index([student_id], map: "idx_enrollments_student_id")
}

/// Cohort-scoped academic assessments (weights, scheduling, rubric linkage).
model assessments {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cohort_id           String            @db.Uuid
  micro_credential_id String            @db.Uuid
  title               String            @db.VarChar(255)
  assessment_type     assessment_type
  weight              Decimal           @db.Decimal(5, 2)
  open_at             DateTime?         @db.Timestamptz(6)
  due_date            DateTime          @db.Timestamptz(6)
  linked_outcome_id   String?           @db.Uuid
  rubric_id           String?           @db.Uuid
  instructions        String?
  /// Quiz / timed assessment: max minutes (null = no per-attempt cap).
  time_limit_minutes  Int?
  /// Max submission attempts (quiz-focused; default 1).
  max_attempts        Int               @default(1)
  shuffle_questions   Boolean           @default(false)
  /// External or future question bank identifier (slug/name until a banks table exists).
  question_bank_ref   String?           @db.VarChar(255)
  /// Suggested submission channel for assignment-like types (maps to `submission_type` enum).
  preferred_submission_type submission_type?
  status              assessment_status @default(draft)
  created_at          DateTime          @default(now()) @db.Timestamptz(6)
  updated_at          DateTime          @default(now()) @db.Timestamptz(6)

  cohorts           cohorts            @relation(fields: [cohort_id], references: [id], onUpdate: NoAction)
  micro_credentials micro_credentials  @relation(fields: [micro_credential_id], references: [id], onUpdate: NoAction)
  learning_outcomes learning_outcomes? @relation(fields: [linked_outcome_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  rubrics           rubrics?           @relation(fields: [rubric_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([cohort_id], map: "idx_assessments_cohort_id")
  @@index([micro_credential_id], map: "idx_assessments_micro_credential_id")
  @@index([linked_outcome_id], map: "idx_assessments_linked_outcome_id")
  @@index([rubric_id], map: "idx_assessments_rubric_id")
  @@index([status], map: "idx_assessments_status")
  submissions submissions[]
  grades      grades[]
}

model evidence_files {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  micro_credential_id String   @db.Uuid
  cohort_id           String   @db.Uuid
  student_id          String?  @db.Uuid
  assessment_id       String?  @db.Uuid
  session_id          String?  @db.Uuid
  evidence_type       String   @db.VarChar(100)
  file_url            String
  title               String   @db.VarChar(255)
  uploaded_by         String?  @db.Uuid
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @db.Timestamptz(6)

  @@index([assessment_id], map: "idx_evidence_files_assessment_id")
  @@index([cohort_id], map: "idx_evidence_files_cohort_id")
  @@index([micro_credential_id], map: "idx_evidence_files_micro_credential_id")
  @@index([session_id], map: "idx_evidence_files_session_id")
  @@index([student_id], map: "idx_evidence_files_student_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model grades {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assessment_id String    @db.Uuid
  student_id    String      @db.Uuid
  grader_id     String?     @db.Uuid
  score         Decimal     @db.Decimal(6, 2)
  feedback      String?
  graded_at     DateTime    @default(now()) @db.Timestamptz(6)
  is_final      Boolean     @default(true)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  updated_at    DateTime    @default(now()) @db.Timestamptz(6)
  assessments   assessments @relation(fields: [assessment_id], references: [id], onDelete: Restrict, onUpdate: NoAction)

  @@unique([assessment_id, student_id, is_final], map: "uq_grades")
  @@index([assessment_id], map: "idx_grades_assessment_id")
  @@index([student_id], map: "idx_grades_student_id")
}

model integrity_cases {
  id             String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cohort_id      String                @db.Uuid
  student_id     String                @db.Uuid
  assessment_id  String?               @db.Uuid
  reported_by    String?               @db.Uuid
  case_type      integrity_case_type
  evidence_notes String?
  decision       String?
  status         integrity_case_status @default(reported)
  created_at     DateTime              @default(now()) @db.Timestamptz(6)
  updated_at     DateTime              @default(now()) @db.Timestamptz(6)

  @@index([cohort_id], map: "idx_integrity_cases_cohort_id")
  @@index([status], map: "idx_integrity_cases_status")
  @@index([student_id], map: "idx_integrity_cases_student_id")
}

model learning_outcomes {
